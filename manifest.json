{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "version": "4.1.3",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "default_locale": "en",
  "icons": {
    "16": "public/favicon-16x16.png",
    "32": "public/favicon-32x32.png",
    "96": "public/favicon-96x96.png",
    "128": "public/favicon-128.png"
  },
  "content_scripts": [
    {
      "js": [
        "src/content.tsx"
      ],
      "matches": [
        "https://*.lacentrale.fr/*",
        "https://*.aramisauto.com/*",
        "https://*.leboncoin.fr/*",
        "https://*.autosphere.fr/*",
        "https://*.autoscout24.fr/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "le-cache-misere@mikaleb.org",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "public/favicon-16x16.png",
        "public/favicon-32x32.png",
        "public/favicon-96x96.png",
        "public/favicon-128.png",
        "favicon-16x16.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
