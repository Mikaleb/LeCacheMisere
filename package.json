{
  "name": "le-cache-misere",
  "private": true,
  "version": "4.1.3",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mikaleb/LeCacheMisere"
  },
  "author": "Mikaleb",
  "scripts": {
    "dev": "vite",
    "dev:ff": "mkdir -p .web-ext && TMPDIR=$PWD/.web-ext web-ext run --source-dir ./dist",
    "start:ff": "concurrently \"npm run watch:ff\" \"wait-on dist/manifest.json && npm run dev:ff\"",
    "watch": "vite build --watch",
    "watch:ff": "vite build --watch",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "zip": "rm -f ../le-cache-misere.zip && cd dist && zip -r ../le-cache-misere.zip . -x '*.git*' && cd ..",
    "deploy": "npm run build && npm run zip",
    "release": "release-it"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.0.1",
    "@mui/material": "^6.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.77.8"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@eslint/js": "^9.9.0",
    "@release-it/bumper": "^6.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "release-it": "^17.6.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "wait-on": "^9.0.4",
    "web-ext": "^8.2.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
